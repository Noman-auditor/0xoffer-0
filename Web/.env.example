# ─────────────────────────────────────────
#  BRANDABLE WEB TEMPLATE — Environment Config
#  Copy to .env and fill in your values
# ─────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Active brand (default | retail | finance | creative | health | your-key)
BRAND=default

# Contact email (where form submissions are sent)
CONTACT_EMAIL=hello@yourcompany.com

# ─── Email Provider (pick ONE) ───────────
# Options: console | resend | sendgrid | nodemailer
MAIL_PROVIDER=console

# Resend (https://resend.com — free 3k/month)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# MAIL_FROM=noreply@yourdomain.com

# SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# MAIL_FROM=noreply@yourdomain.com

# Nodemailer / SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your_smtp_password
# MAIL_FROM=noreply@yourdomain.com

# ─── CORS ────────────────────────────────
# Restrict to your domain in production
CORS_ORIGIN=*
