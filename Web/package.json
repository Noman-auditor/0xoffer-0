{
  "name": "brandable-web-template",
  "version": "1.0.0",
  "description": "Modular, fully brandable web template with Node.js/Express backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start":    "node server.js",
    "dev":      "node --watch server.js",
    "brand:retail":   "BRAND=retail node server.js",
    "brand:finance":  "BRAND=finance node server.js",
    "brand:creative": "BRAND=creative node server.js",
    "brand:health":   "BRAND=health node server.js",
    "lint":     "eslint . --ext .js",
    "test":     "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "cors":                "^2.8.5",
    "express":             "^4.18.2",
    "express-rate-limit":  "^7.1.5",
    "helmet":              "^7.1.0",
    "joi":                 "^17.11.0"
  },
  "optionalDependencies": {
    "resend":          "^2.0.0",
    "@sendgrid/mail":  "^8.1.0",
    "nodemailer":      "^6.9.7"
  },
  "devDependencies": {
    "eslint":  "^8.56.0",
    "jest":    "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["template", "branding", "express", "modular", "frontend"],
  "license": "MIT"
}
